      "background": "art_room",
      "ambient_music": "ambient_tense",
      "dialogue": [
        {
          "character": "mia",
          "text": "...My brother disappeared there. Six months ago. The school says he just transferred. But I know he didn't.",
          "portrait_mood": "sad"
